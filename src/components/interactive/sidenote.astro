---
interface Props {
	id: string;
}

const { id } = Astro.props;
---

<span class="sidenote-wrapper relative">
	<button
		class="sidenote-toggle lg:pointer-events-none inline font-medium text-neutral-500 dark:text-neutral-400 cursor-pointer lg:cursor-default"
		aria-label={`toggle sidenote ${id}`}
		data-sidenote-id={id}
	>
		<sup class="text-xs">{id}</sup>
	</button>
	<span
		class="sidenote-body not-prose hidden lg:block absolute lg:left-[calc(100%+2rem)] lg:top-0 lg:w-56 text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed"
		data-sidenote-body={id}
	>
		<span class="font-medium">{id}:</span>{" "}
		<slot />
	</span>
</span>

<style>
	.sidenote-body.is-open {
		display: block;
		position: relative;
		left: 0;
		top: 0;
		width: 100%;
		margin-top: 0.5rem;
		margin-bottom: 0.5rem;
		padding: 0.75rem;
		background: rgb(245 245 245 / 0.8);
		border-radius: 0.5rem;
	}

	:global(.dark) .sidenote-body.is-open {
		background: rgb(38 38 38 / 0.5);
	}
</style>

<script>
	document.addEventListener("click", (e) => {
		const toggle = (e.target as HTMLElement).closest(".sidenote-toggle");
		if (!toggle || window.innerWidth >= 1024) return;

		const id = toggle.getAttribute("data-sidenote-id");
		const body = document.querySelector(`[data-sidenote-body="${id}"]`);
		if (body) {
			body.classList.toggle("is-open");
		}
	});
</script>
