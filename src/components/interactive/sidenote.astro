---
interface Props {
	id: string;
}

const { id } = Astro.props;
---

<span class="sidenote-wrapper">
	<button
		class="sidenote-toggle xl:pointer-events-none inline font-medium text-neutral-500 dark:text-neutral-400 cursor-pointer xl:cursor-default"
		aria-label={`toggle sidenote ${id}`}
		data-sidenote-id={id}
	>
		<sup class="text-xs">{id}</sup>
	</button>
	<span
		class="sidenote-body not-prose hidden xl:inline text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed"
		data-sidenote-body={id}
	>
		<span class="font-medium">{id}:</span>{" "}
		<slot />
	</span>
</span>

<style>
	/* desktop: float sidenote into right margin */
	@media (min-width: 1280px) {
		.sidenote-body {
			float: right;
			clear: right;
			width: 14rem;
			margin-right: -17rem;
			margin-bottom: 0.5rem;
		}
	}

	/* mobile: toggle open */
	.sidenote-body.is-open {
		display: block;
		width: 100%;
		margin-top: 0.5rem;
		margin-bottom: 0.5rem;
		padding: 0.75rem;
		background: rgb(245 245 245 / 0.8);
		border-radius: 0.5rem;
	}

	:global(.dark) .sidenote-body.is-open {
		background: rgb(38 38 38 / 0.5);
	}
</style>

<script>
	document.addEventListener("click", (e) => {
		const toggle = (e.target as HTMLElement).closest(".sidenote-toggle");
		if (!toggle || window.innerWidth >= 1280) return;

		const id = toggle.getAttribute("data-sidenote-id");
		const body = document.querySelector(`[data-sidenote-body="${id}"]`);
		if (body) {
			body.classList.toggle("is-open");
		}
	});
</script>
